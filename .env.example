# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Google OAuth Configuration (for Calendar Integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Encryption Key for API Keys (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=your_32_byte_encryption_key_base64_encoded

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000

# Feature Flags
ENABLE_DEMO_MODE=false
ENABLE_BYOK=true
# ===========================================
# AI Appointment Setter - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values

# ----- Supabase Configuration -----
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ----- OpenAI Configuration -----
# Required for managed AI service
OPENAI_API_KEY=sk-your-openai-api-key

# ----- Optional: Additional AI Provider Keys -----
# Only needed if supporting BYOK with multiple providers
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
# GOOGLE_AI_API_KEY=your-google-ai-key

# ----- Optional: Google Calendar OAuth -----
# Required for calendar integration
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ----- Application Settings -----
# The base URL of your application (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Security -----
# Secret for encrypting sensitive data (generate with: openssl rand -base64 32)
# ENCRYPTION_SECRET=your-encryption-secret
